# ─── Yandex Cloud Object Storage credentials ───────────────────────────────
# Rename this file to .env and fill in your values.
#
# To create a static access key:
#   Yandex Cloud Console → IAM → Service Accounts → <your-sa> → Create API Key
#   → "Static Access Key"

AWS_ACCESS_KEY_ID=YOUR_STATIC_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_STATIC_SECRET_KEY

# ─── Yandex Object Storage bucket ──────────────────────────────────────────
YC_STORAGE_BUCKET=la-searcher-map
YC_STORAGE_ENDPOINT=https://storage.yandexcloud.net
YC_STORAGE_REGION=us-east-1

# ─── Optional: subfolder in the bucket ─────────────────────────────────────
# If set, files are uploaded to <prefix>/ inside the bucket.
# Leave empty to upload to the bucket root.
# Examples: "v2", "staging", "production"
YC_STORAGE_PREFIX=
